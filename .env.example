# GBLIN MCP — Environment Configuration
#
# Copy this file to `.env` and edit as needed. None of these are strictly
# required: the server falls back to safe defaults if they are absent.

# Base mainnet RPC endpoint.
# - Default: https://base-rpc.publicnode.com (free, no key, generous limits).
# - Recommended for >100 concurrent agents: a paid provider (Alchemy/QuickNode).
#
# Examples:
#   GBLIN_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
#   GBLIN_RPC_URL=https://base-mainnet.infura.io/v3/YOUR_PROJECT_ID
#   GBLIN_RPC_URL=https://base.gateway.tenderly.co/YOUR_KEY
GBLIN_RPC_URL=
